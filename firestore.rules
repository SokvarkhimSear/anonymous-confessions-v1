rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms (Shared Spaces)
    // Document ID: {roomId}
    // Fields:
    //   - name: string (required) - The name of the room
    //   - code: string (required) - The room code
    //   - createdBy: string (required) - The UID of the creator
    //   - members: list (required) - Array of UIDs of users in the room
    //   - createdAt: timestamp (required) - When the room was created
    //
    // Sub-collection: rooms/{roomId}/confessions
    // Document ID: {confessionId}
    // Fields:
    //   - text: string (required, max 1000 chars) - The confession content
    //   - codename: string (optional, max 50 chars) - The user's codename
    //   - userTag: string (optional, max 20 chars) - The user's tag
    //   - animalAlias: string (optional, max 50 chars) - Legacy random animal name
    //   - attachmentUrl: string (optional, max 800000 chars) - Base64 encoded file
    //   - replyTo: string (optional) - ID of the confession being replied to
    //   - reactions: map (optional) - Map of emoji to list of UIDs
    //   - authorUid: string (required) - The UID of the author
    //   - createdAt: timestamp (required) - When the confession was posted
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - codename: string
    //   - photoURL: string
    //   - codenameUpdatedAt: timestamp
    //   - email: string
    //   - userTag: string
    //
    // Collection: forum_posts
    // Document ID: {postId}
    // Fields:
    //   - title: string
    //   - content: string
    //   - authorUid: string
    //   - codename: string
    //   - userTag: string
    //   - attachmentUrl: string (optional, max 800000 chars) - Base64 encoded file
    //   - upvotedBy: list
    //   - downvotedBy: list
    //   - createdAt: timestamp
    //
    // Sub-collection: forum_posts/{postId}/comments
    // Document ID: {commentId}
    // Fields:
    //   - content: string
    //   - authorUid: string
    //   - codename: string
    //   - userTag: string
    //   - attachmentUrl: string (optional)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isDev() {
      return isAuthenticated() && getUserData().role == 'dev';
    }

    function isModerator() {
      return isAuthenticated() && (getUserData().role == 'moderator' || isDev());
    }

    function isRoomAdmin(roomId) {
      let room = get(/databases/$(database)/documents/rooms/$(roomId)).data;
      return isAuthenticated() && (room.memberRoles[request.auth.uid] == 'admin' || room.memberRoles[request.auth.uid] == 'creator' || isDev());
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['name', 'code', 'createdBy', 'members', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.code is string &&
             data.createdBy == request.auth.uid &&
             data.members is list &&
             data.createdAt == request.time;
    }

    function isValidConfession(data) {
      return data.keys().hasAll(['text', 'authorUid', 'createdAt']) &&
             data.text is string && data.text.size() <= 1000 &&
             (data.text.size() > 0 || ('attachmentUrl' in data && data.attachmentUrl.size() > 0)) &&
             (!('animalAlias' in data) || (data.animalAlias is string && data.animalAlias.size() > 0 && data.animalAlias.size() < 50)) &&
             (!('codename' in data) || (data.codename is string && data.codename.size() > 0 && data.codename.size() < 50)) &&
             (!('userTag' in data) || (data.userTag is string && data.userTag.size() > 0 && data.userTag.size() < 20)) &&
             (!('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() < 800000)) &&
             (!('replyTo' in data) || data.replyTo is string) &&
             (!('reactions' in data) || data.reactions is map) &&
             data.authorUid == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidConfessionUpdate(newData, oldData) {
      return newData.diff(oldData).affectedKeys().hasOnly(['reactions']) &&
             newData.reactions is map;
    }

    function isValidForumPost(data) {
      return data.keys().hasAll(['title', 'content', 'authorUid', 'codename', 'userTag', 'upvotedBy', 'downvotedBy', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() <= 5000 &&
             (data.content.size() > 0 || ('attachmentUrl' in data && data.attachmentUrl.size() > 0)) &&
             (!('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() < 800000)) &&
             data.authorUid == request.auth.uid &&
             data.codename is string && data.codename.size() > 0 && data.codename.size() < 50 &&
             data.userTag is string && data.userTag.size() > 0 && data.userTag.size() < 20 &&
             data.upvotedBy is list && data.upvotedBy.size() == 0 &&
             data.downvotedBy is list && data.downvotedBy.size() == 0 &&
             data.createdAt == request.time;
    }

    function isValidForumComment(data) {
      return data.keys().hasAll(['content', 'authorUid', 'codename', 'userTag', 'createdAt']) &&
             data.content is string && data.content.size() <= 5000 &&
             (data.content.size() > 0 || ('attachmentUrl' in data && data.attachmentUrl.size() > 0)) &&
             (!('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() < 800000)) &&
             data.authorUid == request.auth.uid &&
             data.codename is string && data.codename.size() > 0 && data.codename.size() < 50 &&
             data.userTag is string && data.userTag.size() > 0 && data.userTag.size() < 20 &&
             data.createdAt == request.time;
    }

    // Rules for users
    match /users/{userId} {
      // Anyone authenticated can read user profiles (needed to check codename uniqueness)
      allow read: if isAuthenticated();
      // Users can only write their own profile, but cannot change their role
      allow create: if isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == 'user');
      allow update: if isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
    }

    // Rules for rooms (Shared Spaces)
    match /rooms/{roomId} {
      // Anyone authenticated can read rooms (needed to join by code)
      allow read: if isAuthenticated();
      // Users can create rooms
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      // Users can update rooms to join them (add to members array) or manage roles
      allow update: if isAuthenticated() && (
        // Joining
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) && request.resource.data.members.hasAll(resource.data.members)) ||
        // Role management (only creator can promote to admin)
        (resource.data.memberRoles[request.auth.uid] == 'creator' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberRoles'])) ||
        isDev()
      ); 
      allow delete: if isDev() || resource.data.createdBy == request.auth.uid;

      // Rules for confessions sub-collection
      match /confessions/{confessionId} {
        // Anyone authenticated can read confessions in a room
        allow read: if isAuthenticated();
        // Users can create confessions
        allow create: if isAuthenticated() && isValidConfession(request.resource.data);
        allow update: if isAuthenticated() && (isValidConfessionUpdate(request.resource.data, resource.data) || isRoomAdmin(roomId));
        allow delete: if isRoomAdmin(roomId);
      }
    }

    // Rules for forum posts
    match /forum_posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidForumPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotedBy', 'downvotedBy']) &&
         request.resource.data.upvotedBy is list &&
         request.resource.data.downvotedBy is list) ||
        isModerator()
      );
      allow delete: if isOwner(resource.data.authorUid) || isModerator();

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidForumComment(request.resource.data);
        allow delete: if isOwner(resource.data.authorUid) || isModerator();
      }
    }

    // Rules for reports
    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reportedBy == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
